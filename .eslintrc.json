{
  "root": true,
  "extends": [
    "next/core-web-vitals",
    "plugin:@typescript-eslint/recommended"
  ],
  "parser": "@typescript-eslint/parser",
  "plugins": [
    "@typescript-eslint"
  ],
  "ignorePatterns": [
    ".next/",
    "node_modules/",
    "docs/",
    "oldcode/",
    "secrets/"
  ],
  "rules": {
    "@next/next/no-html-link-for-pages": "off"
  }
}
